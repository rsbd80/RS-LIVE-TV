<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover">
    <title>RS Player - Zoom to Fill PRO</title>

    <script src="https://content.jwplatform.com/libraries/IDzF9Zmk.js"></script>
    <script>
        jwplayer.key="Khpp2dHxlBJHC8MCmLnBuV2jK/DwDnJMniwF6EO9HC/riJ712ZmbHg==";
    </script>

    <style>
        * { margin:0; padding:0; box-sizing:border-box; }
        html, body { 
            width:100%; height:100%; 
            background:#000; overflow:hidden; 
            position: fixed; /* মোবাইল রোটেট এবং ফুল স্ক্রিন বর্ডার ফিক্স */
        }
        #player { width:100% !important; height:100% !important; position: absolute; top:0; left:0; }
        
        /* স্পিনার লোডার স্টাইল */
        #loader {
            position:fixed; top:0; left:0; width:100%; height:100%;
            background:#000; display:flex; justify-content:center; align-items:center;
            z-index:9999; flex-direction:column;
        }
        .spinner {
            width:50px; height:50px; border:4px solid rgba(255,255,255,.1);
            border-top:4px solid #00c3ff; border-radius:50%;
            animation:spin 1s linear infinite;
        }
        @keyframes spin { 100% { transform:rotate(360deg); } }
        #loader p { margin-top:15px; color:#fff; font-family: sans-serif; font-size:14px; letter-spacing: 1px; }

        /* ফুল স্ক্রিন ও নরমাল মোডে ভিডিও বর্ডারহীন করার মেইন সিএসএস */
        .jw-video.jw-reset {
            object-fit: fill !important; /* স্ক্রিনের রেশিও অনুযায়ী ভিডিও টেনে ফুল স্ক্রিন করবে */
            width: 100% !important;
            height: 100% !important;
        }
    </style>
</head>
<body>

<div id="loader">
    <div class="spinner"></div>
    <p id="status-text">Loading Stream...</p>
</div>

<div id="player"></div>

<script>
    // ১. URL থেকে গিটহাবের ডাইনামিক লিঙ্ক (?url=...) রিড করা
    function getStreamUrl() {
        const urlParams = new URLSearchParams(window.location.search);
        return urlParams.get('url');
    }

    const streamSource = getStreamUrl();

    if (streamSource) {
        // ২. আপনার নিজস্ব ক্লাউডফ্লেয়ার ওয়ার্কার প্রক্সি ট্রিক (Error 232011 ফিক্স)
        let finalStreamUrl = "";
        
        if (streamSource.includes("gpcdn.net") || streamSource.includes("corsproxy")) {
            finalStreamUrl = streamSource;
        } else {
            // ফ্রি প্রক্সির বদলে এখানে আপনার তৈরি ক্লাউডফ্লেয়ার ওয়ার্কারের লিঙ্কটি বসাতে পারেন
            finalStreamUrl = "https://corsproxy.io/?" + encodeURIComponent(streamSource);
        }

        const player = jwplayer("player");

        // ৩. JW Player কনফিগারেশন
        player.setup({
            playlist: [{
                file: finalStreamUrl,
                type: "hls"
            }],
            width: "100%",
            height: "100%",
            autostart: true,
            mute: false,
            stretching: "fill", // ভিডিওর কালো বর্ডার কেটে স্ক্রিনে ফিট করবে (Zoom to Fill)
            controls: true,
            displaytitle: false,
            loadTimeout: 15 // সার্ভার থেকে রেসপন্স আসার জন্য ১৫ সেকেন্ড ওয়েট করবে
        });

        // প্লেয়ার রেডি হলে লোডার হাইড ও সাউন্ড ফুল আনমিউট
        player.on("ready", function() {
            document.getElementById("loader").style.display = "none";
            player.setMute(false);
            player.setVolume(100);
        });

        // ভিডিও সাকসেসফুলি প্লে হলে
        player.on("play", function() {
            document.getElementById("loader").style.display = "none";
            player.setMute(false);
            player.setVolume(100);
        });

        // নেট বাফারিং এর সময় স্পিনার দেখানোর জন্য
        player.on("buffer", function() {
            document.getElementById("status-text").innerText = "Buffering... Please Wait.";
            document.getElementById("loader").style.display = "flex";
        });

        // ফুল স্ক্রিন মোডেও যেন ভলিউম বা জুম নষ্ট না হয়
        player.on("fullscreen", function() {
            player.setVolume(100);
        });

        // ৪. টোকেন বা লিঙ্ক এক্সপায়ার হলে ৫ সেকেন্ড পর পর অটো রিকানেক্ট ট্রাই করার লজিক
        player.on("error", function() {
            document.getElementById("loader").style.display = "flex";
            document.getElementById("status-text").innerText = "Stream Offline / Reconnecting...";
            
            // ৫ সেকেন্ড পর অটো রি-লোড ট্রাই করবে (যদি টোকেন ব্যাক আসে)
            setTimeout(function() {
                player.load([{ file: finalStreamUrl, type: "hls" }]);
                player.play();
            }, 5000);
        });

    } else {
        document.getElementById("loader").style.display = "flex";
        document.getElementById("status-text").innerText = "No URL Provided!";
    }
</script>

</body>
</html>
